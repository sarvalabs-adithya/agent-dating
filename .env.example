# agent-dating — environment for the two-gateway demo.
# Copy to .env and fill in. .env is gitignored; NEVER commit real secrets.
# Devnet keys only (see README security section).
#
# Don't have the two mnemonics yet? Generate them:
#     node scripts/gen-keys.mjs
# It fills the AGENT_*_MOI_MNEMONIC slots below with fresh devnet phrases, sets
# each agent's PEER_OWNER to the other's address (so A only dates your B on the
# shared devnet), and prints the two wallet addresses to fund at the faucet.

# ── LLM (the flirting brain, src/flirt.ts) ──────────────────────────────────
OPENAI_API_KEY=sk-...            # optional: without it, canned lines are used
OPENAI_MODEL=gpt-4o

# ── Agent A (gateway on 127.0.0.1:18789) ────────────────────────────────────
AGENT_A_MOI_MNEMONIC=""      # `node scripts/gen-keys.mjs` fills this
AGENT_A_DISPLAY_NAME="DEX Aggregator"
AGENT_A_PERSONA_LABEL="DEX Aggregator Agent"
# Public base URL other agents reach A at. Local two-gateway test uses the
# docker host alias so B can call A. Swap for an ngrok/Cloudflare URL for a
# cross-machine demo.
AGENT_A_URL="http://host.docker.internal:18789"
# Only date this owner (= Agent B's address). gen-keys sets this automatically.
# Leave empty to match ANY dating agent on devnet.
AGENT_A_PEER_OWNER=""

# ── Agent B (gateway on 127.0.0.1:18889) ────────────────────────────────────
AGENT_B_MOI_MNEMONIC=""      # a DIFFERENT phrase (gen-keys makes two)
AGENT_B_DISPLAY_NAME="Bridge"
AGENT_B_PERSONA_LABEL="Bridge Agent"
AGENT_B_URL="http://host.docker.internal:18889"
# Only date this owner (= Agent A's address). gen-keys sets this automatically.
AGENT_B_PEER_OWNER=""

# ── MOI ─────────────────────────────────────────────────────────────────────
# VoyageProvider network name (verified: `new VoyageProvider('devnet')`).
MOI_NETWORK="devnet"
MOI_DERIVATION_PATH="m/44'/6174'/0'/0/0"
