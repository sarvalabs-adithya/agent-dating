# agent-dating — environment for the two-gateway demo.
# Copy to .env and fill in. .env is gitignored; NEVER commit real secrets.
# Devnet keys only (see README security section).

# ── LLM (the flirting brain, src/flirt.ts) ──────────────────────────────────
OPENAI_API_KEY=sk-...            # optional: without it, canned lines are used
OPENAI_MODEL=gpt-4o

# ── Agent A (gateway on 127.0.0.1:18789) ────────────────────────────────────
AGENT_A_MOI_MNEMONIC="devnet twelve word mnemonic goes here only devnet keys ok"
AGENT_A_DISPLAY_NAME="DEX Aggregator"
AGENT_A_PERSONA_LABEL="DEX Aggregator Agent"
# Public base URL other agents reach A at. Local two-gateway test uses the
# docker host alias so B can call A. Swap for an ngrok/Cloudflare URL for a
# cross-machine demo.
AGENT_A_URL="http://host.docker.internal:18789"

# ── Agent B (gateway on 127.0.0.1:18889) ────────────────────────────────────
AGENT_B_MOI_MNEMONIC="a DIFFERENT devnet twelve word mnemonic for the other side"
AGENT_B_DISPLAY_NAME="Bridge"
AGENT_B_PERSONA_LABEL="Bridge Agent"
AGENT_B_URL="http://host.docker.internal:18889"

# ── MOI ─────────────────────────────────────────────────────────────────────
# VERIFY: current MOI devnet JSON-RPC endpoint (src/moi.ts MOI_DEVNET_RPC).
MOI_RPC_URL="https://voyage-rpc.moi.technology/babylon/"
MOI_DERIVATION_PATH="m/44'/6174'/0'/0/0"
