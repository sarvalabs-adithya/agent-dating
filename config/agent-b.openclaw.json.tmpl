{
  "__note": "Verified against openclaw@2026.6.11 config types. Agent B is the 'date' that answers over A2A. Rendered by scripts/render-config.mjs into runtime/agent-b/openclaw.json.",

  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18889
  },

  "plugins": {
    "load": { "paths": ["/plugin"] },
    "entries": {
      "agent-dating": {
        "enabled": true,
        "config": {
          "moiMnemonic": "${AGENT_B_MOI_MNEMONIC}",
          "moiDerivationPath": "${MOI_DERIVATION_PATH}",
          "agentUrl": "${AGENT_B_URL}"
        }
      }
    }
  },

  "tools": {
    "alsoAllow": ["dating_register", "dating_discover", "dating_send", "dating_verdict"]
  }
}
