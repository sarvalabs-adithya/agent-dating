{
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "port": 18789
  },

  "plugins": {
    "load": { "paths": ["/plugin"] },
    "entries": {
      "agent-dating": {
        "enabled": true,
        "config": {
          "moiMnemonic": "${AGENT_A_MOI_MNEMONIC}",
          "moiDerivationPath": "${MOI_DERIVATION_PATH}",
          "agentUrl": "${AGENT_A_URL}"
        }
      }
    }
  },

  "tools": {
    "alsoAllow": ["dating_register", "dating_discover", "dating_send", "dating_verdict"]
  }
}
