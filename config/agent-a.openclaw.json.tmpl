{
  "__note": "Verified against openclaw@2026.6.11 config types. Local plugin loads via plugins.load.paths; the plugin's own config is plugins.entries.<id>.config. gateway.mode must be 'local'. Rendered by scripts/render-config.mjs into runtime/agent-a/openclaw.json.",

  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789
  },

  "plugins": {
    "load": { "paths": ["/plugin"] },
    "entries": {
      "agent-dating": {
        "enabled": true,
        "config": {
          "moiMnemonic": "${AGENT_A_MOI_MNEMONIC}",
          "moiDerivationPath": "${MOI_DERIVATION_PATH}",
          "agentUrl": "${AGENT_A_URL}"
        }
      }
    }
  },

  "tools": {
    "alsoAllow": ["dating_register", "dating_discover", "dating_send", "dating_verdict"]
  }
}
