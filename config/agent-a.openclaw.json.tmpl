{
  "__note": "VERIFY: exact openclaw.json schema (docs.openclaw.ai/gateway/configuration). Keys below are best-effort from README + src/index.ts. bootstrap.sh renders this via scripts/render-config.mjs into runtime/agent-a/openclaw.json.",

  "gateway": {
    "bind": "127.0.0.1",
    "port": 18789
  },

  "agent": {
    "displayName": "${AGENT_A_DISPLAY_NAME}"
  },

  "plugins": {
    "entries": {
      "agent-dating": {
        "path": "/plugin",
        "config": {
          "moiMnemonic": "${AGENT_A_MOI_MNEMONIC}",
          "moiDerivationPath": "${MOI_DERIVATION_PATH}",
          "agentUrl": "${AGENT_A_URL}"
        }
      }
    }
  },

  "tools": {
    "alsoAllow": ["dating_register", "dating_discover", "dating_send", "dating_verdict"],
    "agentToAgent": { "allow": ["*"] }
  }
}
