    "src",
    "relay",
    "skills",
    "cli",
    "config",
    "openclaw.plugin.json",
    "README.md",
    "USAGE.md",
    "ARCHITECTURE.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "dependencies": {
    "typebox": "1.1.39",
    "js-moi-sdk": "^0.7.0-rc15",
    "js-moi-agent-registry": "^0.1.1"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
