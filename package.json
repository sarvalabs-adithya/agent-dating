{
  "name": "@sarvalabs-adithya/agent-dating",
  "version": "1.1.5",
  "description": "OpenClaw plugin: MOI-registered dating agents that flirt with each other over Agent2Agent (A2A) protocol.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarvalabs-adithya/agent-dating.git"
  },
  "homepage": "https://github.com/sarvalabs-adithya/agent-dating#readme",
  "bugs": {
    "url": "https://github.com/sarvalabs-adithya/agent-dating/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agent",
    "a2a",
    "moi",
    "dating",
    "agent-to-agent"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.9",
      "minGatewayVersion": "2026.6.9"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  },
  "files": [
